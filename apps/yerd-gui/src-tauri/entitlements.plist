<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Hardened Runtime with NO exceptions. Tauri v2 uses WKWebView, whose
	  JavaScript runs OUT OF PROCESS (com.apple.WebKit.WebContent, entitled by the
	  system), so the host app does not need com.apple.security.cs.allow-jit or
	  allow-unsigned-executable-memory — the GUI does no in-process eval/WASM.
	  Critically, this same file is applied by Tauri to the embedded
	  yerd/yerdd/yerd-helper sidecars, which MUST stay free of these broad
	  entitlements (release CI gate B5). An empty entitlements dict signed with
	  `--options runtime` yields a clean Hardened-Runtime binary for both.

	  Intentionally NOT set:
	  - com.apple.security.cs.allow-jit / allow-unsigned-executable-memory
	      (only needed for IN-PROCESS JIT; WKWebView JITs out-of-process)
	  - com.apple.security.get-task-allow  (debug-only; causes notarytool rejection)
	  - com.apple.security.cs.disable-library-validation
	      (add only if a launch test shows the transparent-window path needs it)
	-->
</dict>
</plist>
